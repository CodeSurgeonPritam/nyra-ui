# ---------------------------------------------------------------------------
# Nyra environment variables
# ---------------------------------------------------------------------------
# Copy to `.env.local` for local dev. None of these are required to run the
# marketing surface — missing Pro-tier vars trigger graceful degradation:
# /pricing shows a "coming soon" CTA, /dashboard shows a placeholder, Pro
# component detail pages show the paywall preview without checkout.
# ---------------------------------------------------------------------------

# Site
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (Neon Postgres) — required for Pro tier persistence
# https://neon.tech → Project → Connection details → connection string
DATABASE_URL=""

# Clerk — required for auth on /dashboard /account
# https://dashboard.clerk.com → New application → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Lemon Squeezy — required for /pricing checkout and webhook reconciliation
# https://app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
# Webhook: created at https://app.lemonsqueezy.com → Settings → Webhooks
# Endpoint: ${NEXT_PUBLIC_APP_URL}/api/lemonsqueezy/webhook
LEMONSQUEEZY_WEBHOOK_SECRET=""

# Product variant IDs (find each variant in Lemon Squeezy → Store → Products)
LEMONSQUEEZY_PRO_VARIANT_ID=""           # Pro monthly
LEMONSQUEEZY_PRO_YEARLY_VARIANT_ID=""    # Pro yearly
LEMONSQUEEZY_PRO_LIFETIME_VARIANT_ID=""  # Pro lifetime (one-time payment)

# Email — Resend (newsletter + welcome series)
# https://resend.com → API Keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Nyra <hello@nyra.dev>"
# Optional — create at https://resend.com → Audiences. When set, the
# newsletter endpoint adds new subscribers to this audience list.
RESEND_AUDIENCE_ID=""

# Analytics — Plausible (privacy-friendly, no cookies)
# Leave blank to disable analytics. Self-hosted? Override the script URL.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT="https://plausible.io/js/script.js"

# Error tracking — Sentry (run `npx @sentry/wizard@latest -i nextjs` to install)
# When NEXT_PUBLIC_SENTRY_DSN is set, Sentry captures runtime errors in the
# browser and on the server. Until then errors land in the platform logs.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
